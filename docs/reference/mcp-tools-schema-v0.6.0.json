    {
      "description": "mesh 토론을 시작한다(v2-56). 좌석=로스터 online 에이전트 2~6석(라이브 세션 좌석은 live:true 필수), 유한 라운드(기본 3, 최대 10, 순차-인지) 후 synthesizer(기본=첫 좌석) 종합 1회. 전사=debate:<id> 세션(read_transcript로 열람), 결과 수신=watch-results --dispatcher debate:<id>. 비동기 작업이다(좌석당 수 분).",
      "inputSchema": {
        "$defs": {
          "DiscussionSeatParams": {
            "description": "start_discussion 좌석 파라미터(v2-56 mesh 토론).",
            "properties": {
              "agent": {
                "description": "좌석 에이전트 uuid(로스터 online 필수, list_agents로 발견).",
                "type": "string"
              },
              "instruction": {
                "description": "좌석별 추가 지시(자유 텍스트, 역할 지시문 뒤에 덧붙는다).",
                "type": [
                  "string",
                  "null"
                ]
              },
              "label": {
                "description": "전사·프롬프트 표기용 라벨(생략 시 로스터 display_name, 그것도 없으면 uuid 앞 8자).",
                "type": [
                  "string",
                  "null"
                ]
              },
              "live": {
                "description": "라이브 세션 좌석 명시 동의(v2-56 §8-3). 로스터 role=session 에이전트는 true 필수\n(사람이 쓰는 세션을 실수로 토론에 끌어들이는 것 방지).",
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "role": {
                "description": "토론 역할(proposer/reviewer/verifier/synthesizer 별칭 포함. 그 외 문자열은 역할 지시문 없이 무시).",
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "agent"
            ],
            "type": "object"
          }
        },
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "gate": {
            "description": "라운드 간 사람 승인 게이트(이슈 #131, 옵트인·기본 false). true면 각 라운드 완료 시(종합 직전\n포함) 다이제스트가 인박스로 배달되고 continue_discussion까지 대기한다. 승인 주체는 사람이다.",
            "type": [
              "boolean",
              "null"
            ]
          },
          "rounds": {
            "description": "라운드 수(기본 3, 1~10로 클램프). 소진 후 synthesizer 종합 1회가 추가로 돈다.",
            "format": "uint32",
            "minimum": 0,
            "type": [
              "integer",
              "null"
            ]
          },
          "seats": {
            "description": "좌석 2~6석. 배열 순서 = 라운드 내 발언 순서(순차-인지: 뒤 좌석이 앞 좌석 답을 본다).",
            "items": {
              "$ref": "#/$defs/DiscussionSeatParams"
