    {
      "description": "머신당 presence 스캐너가 라이브 세션 전집합을 일괄 보고한다(upsert+소유분 제거, v2-44).",
      "inputSchema": {
        "$defs": {
          "PresenceSessionInput": {
            "description": "report_presence 툴의 라이브 세션 한 건(presence 스캐너가 보고, 설계 v2-44 §6).",
            "properties": {
              "active_at": {
                "default": null,
                "description": "스캐너가 관측한 마지막 활동 시각(이슈 #123, codex rollout mtime). DB datetime 포맷.\n생략 가능(claude=turn-ping 훅 경로). 브로커가 인메모리 turn_active_at과 max-merge한다.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "display_name": {
                "description": "로스터 가독용 표시 이름(예: win-claude-tunaRound). 생략 가능.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "human_input_at": {
                "default": null,
                "description": "스캐너가 관측한 마지막 사람 입력 시각(v2-45 P5, codex rollout user_message). DB datetime 포맷.\n생략 가능(claude 세션·신호 없음). 브로커가 인메모리·영속과 max-merge한다.",
                "type": [
                  "string",
                  "null"
                ]
              },
              "project": {
                "description": "추정 프로젝트(불명이면 생략).",
                "type": [
                  "string",
                  "null"
                ]
              },
              "runner": {
                "description": "러너 종류(claude | codex).",
                "type": "string"
              },
              "uuid": {
                "description": "세션 id(claude=jsonl stem, codex=rollout uuid). roster uuid와 같은 공간.",
                "type": "string"
              }
            },
            "required": [
              "uuid",
              "runner"
            ],
            "type": "object"
          }
        },
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "machine": {
            "description": "이 스캐너의 머신 식별자(win|mac|unix).",
            "type": "string"
          },
          "sessions": {
            "description": "이 머신의 라이브 세션 전집합.",
            "items": {
              "$ref": "#/$defs/PresenceSessionInput"
            },
            "type": "array"
          }
        },
        "required": [
          "machine",
          "sessions"
        ],
        "type": "object"
      },
      "name": "report_presence"
    },
    {
